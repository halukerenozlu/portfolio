---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects", ({ data }) => !data.draft);

const projects = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return Number(b.data.featured) - Number(a.data.featured);
  }

  return a.data.order - b.data.order;
});
---

<Layout
  title="Haluk Eren | Portfolio"
  description="Portfolio website built with Astro, React, TypeScript, Tailwind CSS, and MDX."
>
  <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/70 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="#hero" class="text-sm font-semibold tracking-[0.2em] text-white uppercase">
        Portfolio
      </a>

      <nav class="hidden gap-6 text-sm text-slate-300 md:flex">
        <a href="#about" class="transition hover:text-white">About</a>
        <a href="#experience" class="transition hover:text-white">Experience</a>
        <a href="#projects" class="transition hover:text-white">Projects</a>
        <a href="#contact" class="transition hover:text-white">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section id="hero" class="px-6 pb-20 pt-24 md:pb-28 md:pt-32">
      <div class="mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2">
        <div>
          <p class="mb-4 text-sm font-medium uppercase tracking-[0.25em] text-fuchsia-400">
            Computer Engineering Student
          </p>

          <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-white md:text-6xl">
            Building clean, modern, and reliable web experiences.
          </h1>

          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
            I am building a portfolio focused on strong structure, fast delivery, and a modern visual style
            with Astro, React, TypeScript, Tailwind CSS, and MDX.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="#projects"
              class="rounded-full bg-fuchsia-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-fuchsia-400"
            >
              View Projects
            </a>

            <a
              href="#contact"
              class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-200 transition hover:border-white/30 hover:text-white"
            >
              Contact Me
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-square rounded-3xl border border-white/10 bg-white/5 p-3 shadow-2xl shadow-fuchsia-950/30">
            <div class="flex h-full items-center justify-center rounded-[1.25rem] border border-white/10 bg-gradient-to-br from-fuchsia-500/10 via-slate-900 to-slate-950 text-center">
              <div>
                <p class="text-sm uppercase tracking-[0.3em] text-fuchsia-300">Profile Visual</p>
                <p class="mt-3 text-2xl font-semibold text-white">Image Placeholder</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="border-t border-white/10 bg-white/5 px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <h2 class="mb-10 text-center text-3xl font-bold text-white md:text-4xl">About Me</h2>

        <div class="grid gap-8 md:grid-cols-2">
          <div class="space-y-5 text-lg leading-8 text-slate-300">
            <p>
              I am a Computer Engineering student focused on building solid engineering fundamentals while creating
              practical and presentable software projects.
            </p>
            <p>
              My goal with this portfolio is to present my work in a cleaner, more professional, and more structured
              way without sacrificing performance.
            </p>
            <p>
              I want the site to feel modern, polished, and highly intentional while remaining easy to maintain and
              safe to deploy.
            </p>
          </div>

          <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-8">
            <h3 class="mb-5 text-xl font-semibold text-white">Key Focus</h3>
            <ul class="space-y-3 text-slate-300">
              <li>• Frontend architecture and clean UI structure</li>
              <li>• Type-safe development with TypeScript</li>
              <li>• Component-based thinking with React</li>
              <li>• Static-first delivery with Astro</li>
              <li>• Project content management with MDX</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="experience" class="px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <h2 class="mb-10 text-center text-3xl font-bold text-white md:text-4xl">Experience</h2>

        <div class="space-y-6">
          <article class="rounded-3xl border-l-4 border-fuchsia-500 bg-white/5 p-6 shadow-lg shadow-black/20">
            <div class="mb-3 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-xl font-bold text-white">Computer Engineering Student</h3>
                <p class="text-fuchsia-400">Academic and Personal Projects</p>
              </div>
              <p class="text-slate-400">Current Phase</p>
            </div>

            <ul class="space-y-2 text-slate-300">
              <li>• Building a modern portfolio with Astro and MDX</li>
              <li>• Strengthening project presentation and frontend engineering habits</li>
              <li>• Creating a reusable structure for future personal work</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section id="projects" class="border-t border-white/10 bg-white/5 px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <h2 class="mb-10 text-center text-3xl font-bold text-white md:text-4xl">Featured Projects</h2>

        <div class="grid gap-8 md:grid-cols-2">
          {projects.map((project) => (
            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-black/20">
              <div class="mb-4 aspect-video rounded-2xl border border-white/10 bg-gradient-to-br from-fuchsia-500/10 to-slate-900"></div>

              <h3 class="text-2xl font-semibold text-white">{project.data.title}</h3>
              <p class="mt-2 text-slate-300">{project.data.description}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {project.data.tech.map((item) => (
                  <span class="rounded-full border border-fuchsia-400/20 bg-fuchsia-500/10 px-3 py-1 text-sm text-fuchsia-200">
                    {item}
                  </span>
                ))}
              </div>

              <div class="mt-6 flex flex-wrap gap-3">
                <a
                  href={`/projects/${project.id}/`}
                  class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-slate-200"
                >
                  View Details
                </a>

                {project.data.github && (
                  <a
                    href={project.data.github}
                    target="_blank"
                    rel="noreferrer"
                    class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-semibold text-slate-200 transition hover:border-white/30 hover:text-white"
                  >
                    GitHub
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="px-6 py-20">
      <div class="mx-auto max-w-4xl rounded-3xl border border-white/10 bg-slate-900/70 p-10 text-center shadow-lg shadow-black/20">
        <h2 class="text-3xl font-bold text-white md:text-4xl">Contact</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-300">
          The first version will stay static and deploy-safe. We will add richer interactivity after the base structure
          is complete.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="mailto:you@example.com"
            class="rounded-full bg-fuchsia-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-fuchsia-400"
          >
            Send Email
          </a>

          <a
            href="https://github.com/your-username"
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-slate-200 transition hover:border-white/30 hover:text-white"
          >
            GitHub
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>