---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/sections/Navbar.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import TechnicalSkills from "../components/sections/TechnicalSkills.astro";
import Experience from "../components/sections/Experience.astro";
import Projects from "../components/sections/Projects.astro";
import Contact from "../components/sections/Contact.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects", ({ data }) => !data.draft);

const projects = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return Number(b.data.featured) - Number(a.data.featured);
  }

  return a.data.order - b.data.order;
});
---

<Layout
  title="Portfolio"
  description="A modern portfolio built with Astro, React, TypeScript, Tailwind CSS, and MDX."
>
  <Navbar />
  <main>
    <Hero />
    <About />
    <TechnicalSkills />
    <Experience />
    <Projects projects={projects} />
    <Contact />
  </main>
</Layout>
