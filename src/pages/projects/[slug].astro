---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.title} | Portfolio`} description={project.data.description}>
  <main class="px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <a href="/#projects" class="text-sm text-indigo-600 transition hover:text-indigo-500 dark:text-fuchsia-400 dark:hover:text-fuchsia-300">
        Back to projects
      </a>

      <div class="mt-6 rounded-3xl border border-slate-200/80 bg-white p-8 shadow-lg shadow-slate-200/40 dark:border-white/10 dark:bg-slate-900/70 dark:shadow-black/20">
        <h1 class="text-4xl font-bold text-slate-900 dark:text-white">{project.data.title}</h1>
        <p class="mt-4 text-lg leading-8 text-slate-600 dark:text-slate-300">{project.data.description}</p>

        <div class="mt-6 flex flex-wrap gap-2">
          {project.data.tech.map((item) => (
            <span class="rounded-full border border-indigo-400/20 bg-indigo-500/10 px-3 py-1 text-sm text-indigo-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">
              {item}
            </span>
          ))}
        </div>

        <div class="prose mt-10 max-w-none prose-headings:text-slate-900 prose-p:text-slate-700 prose-li:text-slate-700 dark:prose-invert dark:prose-headings:text-white dark:prose-p:text-slate-300 dark:prose-li:text-slate-300">
          <Content />
        </div>
      </div>
    </div>
  </main>
</Layout>
