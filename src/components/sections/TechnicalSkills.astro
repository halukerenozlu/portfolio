---
import { skillGroups } from "../../data/skills";
---

<section id="skills" class="px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-10 text-center text-3xl font-bold text-slate-900 md:text-4xl dark:text-white">Technical Skills</h2>

    <div class="grid gap-6 md:grid-cols-2">
      {skillGroups.map((group) => (
        <article class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-lg shadow-slate-200/40 dark:border-white/10 dark:bg-white/5 dark:shadow-black/20">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">{group.title}</h3>

          <div class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class={`inline-flex items-center gap-2 rounded-full border px-3 py-1 text-sm ${item.tone}`}>
                <img src={item.icon} alt={`${item.name} icon`} class="h-4 w-4 shrink-0" loading="lazy" decoding="async" />
                <span>{item.name}</span>
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
