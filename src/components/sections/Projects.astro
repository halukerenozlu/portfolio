---
import type { ProjectsSectionProps as Props } from "../../types";

const { projects } = Astro.props;
---

<section id="projects" class="border-y border-slate-200/80 bg-slate-100/70 px-6 py-20 dark:border-white/10 dark:bg-white/5">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-10 text-center text-3xl font-bold text-slate-900 md:text-4xl dark:text-white">Featured Projects</h2>

    <div class="grid gap-8 md:grid-cols-2">
      {projects.map((project) => (
        <article class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-lg shadow-slate-200/40 dark:border-white/10 dark:bg-slate-900/70 dark:shadow-black/20">
          <div class="mb-4 aspect-video rounded-2xl border border-slate-200 bg-linear-to-br from-indigo-500/10 to-slate-100 dark:border-white/10 dark:from-fuchsia-500/10 dark:to-slate-900"></div>

          <h3 class="text-2xl font-semibold text-slate-900 dark:text-white">{project.data.title}</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-300">{project.data.description}</p>

          <div class="mt-4 flex flex-wrap gap-2">
            {project.data.tech.map((item) => (
              <span class="rounded-full border border-indigo-400/20 bg-indigo-500/10 px-3 py-1 text-sm text-indigo-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">
                {item}
              </span>
            ))}
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={`/projects/${project.id}/`}
              class="rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200"
            >
              View Details
            </a>

            {project.data.github && (
              <a
                href={project.data.github}
                target="_blank"
                rel="noreferrer"
                class="rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-900 dark:border-white/15 dark:text-slate-200 dark:hover:border-white/30 dark:hover:text-white"
              >
                GitHub
              </a>
            )}

            {project.data.demo && (
              <a
                href={project.data.demo}
                target="_blank"
                rel="noreferrer"
                class="rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-900 dark:border-white/15 dark:text-slate-200 dark:hover:border-white/30 dark:hover:text-white"
              >
                Live Demo
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
